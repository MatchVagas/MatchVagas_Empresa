<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    app:cardCornerRadius="12dp"
    app:cardElevation="3dp"
    app:cardBackgroundColor="@color/surface"
    android:layout_marginBottom="10dp"
    android:clickable="true"
    android:focusable="true">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <!-- Barra lateral colorida pelo status -->
        <View
            android:id="@+id/view_status_stripe"
            android:layout_width="5dp"
            android:layout_height="0dp"
            android:background="@color/status_pendente"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent" />

        <!-- Conteúdo principal -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:padding="14dp"
            android:gravity="center_vertical"
            app:layout_constraintStart_toEndOf="@id/view_status_stripe"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent">

            <!-- Avatar circular com iniciais -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="52dp"
                android:layout_height="52dp"
                app:cardCornerRadius="26dp"
                app:cardBackgroundColor="@color/primary_light"
                app:cardElevation="0dp"
                android:layout_marginEnd="14dp">

                <TextView
                    android:id="@+id/tv_iniciais"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:text="AB"
                    android:textSize="17sp"
                    android:textStyle="bold"
                    android:textColor="@color/primary"
                    android:gravity="center" />
            </com.google.android.material.card.MaterialCardView>

            <!-- Coluna de informações -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/tv_nome_candidato"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Ana Beatriz Silva"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:textColor="@color/text_primary"
                    android:maxLines="1"
                    android:ellipsize="end"
                    android:layout_marginBottom="2dp" />

                <TextView
                    android:id="@+id/tv_titulo_vaga"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Desenvolvedor Android"
                    android:textSize="12sp"
                    android:textColor="@color/primary"
                    android:maxLines="1"
                    android:ellipsize="end"
                    android:layout_marginBottom="6dp" />

                <!-- Data com ícone de calendário -->
                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <ImageView
                        android:layout_width="12dp"
                        android:layout_height="12dp"
                        android:src="@drawable/ic_calendar"
                        android:tint="@color/text_secondary"
                        android:layout_marginEnd="4dp" />

                    <TextView
                        android:id="@+id/tv_data_candidatura"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="01/05/2026"
                        android:textSize="11sp"
                        android:textColor="@color/text_secondary" />
                </LinearLayout>
            </LinearLayout>

            <!-- Coluna direita: badge de status + seta -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center_horizontal"
                android:layout_marginStart="10dp">

                <TextView
                    android:id="@+id/tv_status"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Pendente"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:textColor="@color/white"
                    android:background="@drawable/bg_badge_pendente"
                    android:paddingStart="10dp"
                    android:paddingEnd="10dp"
                    android:paddingTop="5dp"
                    android:paddingBottom="5dp"
                    android:gravity="center" />

                <ImageView
                    android:layout_width="16dp"
                    android:layout_height="16dp"
                    android:src="@drawable/ic_arrow_back"
                    android:tint="@color/text_hint"
                    android:rotation="180"
                    android:layout_marginTop="12dp" />
            </LinearLayout>

        </LinearLayout>
    </androidx.constraintlayout.widget.ConstraintLayout>
</com.google.android.material.card.MaterialCardView>
