<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    app:cardCornerRadius="12dp"
    app:cardElevation="2dp"
    app:cardBackgroundColor="@color/surface"
    android:layout_marginBottom="10dp"
    android:clickable="true"
    android:focusable="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="16dp"
        android:gravity="center_vertical">

        <!-- Avatar com iniciais -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="48dp"
            android:layout_height="48dp"
            app:cardCornerRadius="24dp"
            app:cardBackgroundColor="@color/primary_light"
            android:layout_marginEnd="14dp">

            <TextView
                android:id="@+id/tv_iniciais"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:text="AB"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="@color/primary"
                android:gravity="center" />
        </com.google.android.material.card.MaterialCardView>

        <!-- Info do candidato -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tv_nome_candidato"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Ana Beatriz Silva"
                android:textSize="15sp"
                android:textStyle="bold"
                android:textColor="@color/text_primary"
                android:layout_marginBottom="4dp" />

            <TextView
                android:id="@+id/tv_data_candidatura"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Candidatou-se em 01/05/2026"
                android:textSize="12sp"
                android:textColor="@color/text_secondary" />
        </LinearLayout>

        <!-- Badge de status -->
        <TextView
            android:id="@+id/tv_status"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Pendente"
            android:textSize="11sp"
            android:textColor="@color/white"
            android:background="@drawable/bg_badge_pendente"
            android:paddingStart="10dp"
            android:paddingEnd="10dp"
            android:paddingTop="4dp"
            android:paddingBottom="4dp" />
    </LinearLayout>
</com.google.android.material.card.MaterialCardView>
